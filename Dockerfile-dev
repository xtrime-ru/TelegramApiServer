FROM xtrime/telegram-api-server:latest

RUN echo "opcache.jit=disable" > "$PHP_INI_DIR/conf.d/tmp.ini"

RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        autoconf g++ gcc make pkg-config; \
    rm -rf /var/lib/apt/lists/*; \
    pecl install xdebug; \
    rm -f "$PHP_INI_DIR/conf.d/docker-php-ext-xdebug.ini" "$PHP_INI_DIR/conf.d/tmp.ini";

ADD dev/xdebug.ini $PHP_INI_DIR/conf.d/xdebug.ini

EXPOSE 9503
EXPOSE 9003

ENTRYPOINT ["./entrypoint.sh"]
